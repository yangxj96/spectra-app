# =================================================
# 环境变量模板
# 复制此文件为 .env（本地覆盖）或对应环境文件后修改
# =================================================

# API 基础地址
VITE_API_BASE_URL = "https://api.example.com"

# 是否启用开发模式（true 时跳过登录校验等）
VITE_DEV_MODE = false

# 应用标题
VITE_APP_TITLE = "光谱"

# 是否启用接口加解密（true=启用，需要配合后端 spectra.system.sm.enabled=true）
VITE_CRYPTO_ENABLED = false

# RSA 公钥（Base64 格式，加密请求 / 验签响应用）
VITE_RSA_PUBLIC_KEY = ""

# RSA 私钥（Base64 格式，解密响应 / 签名请求用）
VITE_RSA_PRIVATE_KEY = ""
