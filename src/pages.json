{
    "easycom": {
        "autoscan": true,
        "custom": {
            // uni-ui 规则配置
            "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
            // tdesign 规则配置
            "^t-(.*)": "@tdesign/uniapp/$1/$1.vue"
        }
    },
    "pages": [
        //pages数组中第一项表示应用启动页，参考：https://doc.dcloud.net.cn/uni-app-x/collocation/pagesjson.html
        {
            "path": "pages/splash/index",
            "style": {
                "navigationBarTitleText": "启动中"
            }
        },
        {
            "path": "pages/login/index",
            "style": {
                "navigationBarTitleText": "登陆"
            }
        },
        {
            "path": "pages/message/index",
            "style": {
                "navigationBarTitleText": "消息"
            }
        },
        {
            "path": "pages/contacts/index",
            "style": {
                "navigationBarTitleText": "通讯录"
            }
        },
        {
            "path": "pages/workbench/index",
            "style": {
                "navigationBarTitleText": "工作台"
            }
        },
        {
            "path": "pages/mine/index",
            "style": {
                "navigationBarTitleText": "我"
            }
        }
    ],
    // 分包
    "subPackages": [
        // 聊天
        {
            "root": "subpackages/message",
            "pages": [
                {
                    "path": "chat/index",
                    "style": {
                        "navigationBarTitleText": "聊天"
                    }
                },
                {
                    "path": "group/index",
                    "style": {
                        "navigationBarTitleText": "群聊"
                    }
                }
            ]
        }
    ],
    // 分包预加载
    "preloadRule": {
        // 意思是进入这个页面的时候预加载这个分包，参考：https://doc.dcloud.net.cn/uni-app-x/collocation/pagesjson.html
        "pages/message/index": {
            "network": "all",
            "packages": ["subpackages/message"]
        }
    },
    "globalStyle": {
        "navigationBarTextStyle": "black",
        "navigationBarTitleText": "光谱",
        "navigationBarBackgroundColor": "#F8F8F8",
        "navigationStyle": "custom",
        "backgroundColor": "#F8F8F8"
    },
    "tabBar": {
        "iconfontSrc": "static/iconfont/iconfont.ttf",
        "color": "#999999",
        "selectedColor": "#007AFF",
        "backgroundColor": "#FFFFFF",
        "borderStyle": "black",
        "list": [
            {
                "pagePath": "pages/message/index",
                "text": "消息",
                "iconPath": "static/tab_bar/message.png",
                "selectedIconPath": "static/tab_bar/message_s.png"
            },
            {
                "pagePath": "pages/contacts/index",
                "text": "通讯录",
                "iconPath": "static/tab_bar/contacts.png",
                "selectedIconPath": "static/tab_bar/contacts_s.png"
            },
            {
                "pagePath": "pages/workbench/index",
                "text": "工作台",
                "iconPath": "static/tab_bar/workbench.png",
                "selectedIconPath": "static/tab_bar/workbench_s.png"
            },
            {
                "pagePath": "pages/mine/index",
                "text": "我",
                "iconPath": "static/tab_bar/mine.png",
                "selectedIconPath": "static/tab_bar/mine_s.png"
            }
        ]
    }
}
