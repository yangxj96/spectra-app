{
  "name": "uni-preset-vue",
  "version": "0.0.0",
  "scripts": {
    "start": "npm run dev:h5",
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "prestart": "npm run type-check && npm run lint && npm run format",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-5000720260410001",
    "@dcloudio/uni-app-harmony": "3.0.0-5000720260410001",
    "@dcloudio/uni-app-plus": "3.0.0-5000720260410001",
    "@dcloudio/uni-components": "3.0.0-5000720260410001",
    "@dcloudio/uni-h5": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5000720260410001",
    "@dcloudio/uni-ui": "^1.5.12",
    "@tdesign/uniapp": "^0.8.1",
    "pinia": "^2.1.7",
    "vue": "3.4.27",
    "vue-i18n": "~9.1.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@dcloudio/types": "3.4.28",
    "@dcloudio/uni-automator": "3.0.0-5000720260410001",
    "@dcloudio/uni-cli-shared": "3.0.0-5000720260410001",
    "@dcloudio/uni-stacktracey": "3.0.0-5000720260410001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5000720260410001",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vue/runtime-core": "3.5.32",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "typescript": "~5.4.5",
    "typescript-eslint": "^8.62.0",
    "vite": "5.2.8",
    "vue-tsc": "~2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,jsx}": [
      "eslint . --fix",
      "prettier --write"
    ],
    "*.{json,scss,css,less,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
